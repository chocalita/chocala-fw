{
  "name": "isaxbo/chocala",
  "require": {
    "monolog/monolog": "1.0.*",
    "propel/propel": "~2.0@dev",
    "facebook/php-sdk-v4": "~5.0",
    "sendinblue/api-v3-sdk": "^6.1.0",
    "league/plates": "3.*",
    "latte/latte": "2.*"
  },
  "require-dev": {
    "phpunit/phpunit": "^7"
  },
  "autoload": {
    "classmap": [
      "App/model/domain/"
    ],
    "psr-4": {
      "Chocala\\": "src/Chocala"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://packagist.org"
    },
    {
      "packagist": false
    }
  ],
  "config": {
    "vendor-dir": "Vendor"
  }
}
